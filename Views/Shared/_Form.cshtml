                        <td>
                            <input asp-for="EndTime" type="time" onfocus="clearError(this)" class="vTimeEnd" />
                        </td>
              
                    </tr>
                </table>
            
                <div class="row d-flex justify-content-center mt-100">
                    <div class="col-md-6">
                        <select asp-for="Days" id="choices-multiple-remove-button" placeholder="Select upto 5 tags" multiple>
                            <option value="Monday">Monday</option>
                            <option value="Jquery">Jquery</option>
                        
                        </select>
                    </div>
                </div>*@
                <div class="modal-footer bg-dark">
                    <button type="submit" id="btnSubmit" class="btn btn-success">Submit</button>
                    <button type="button" id="btnDismiss" class="btn btn-primary" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

