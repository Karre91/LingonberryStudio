@model LingonberryStudio.Data.Entities.Advert

@using (Html.BeginForm("CreateAd", "Adverts", FormMethod.Post))
{
    <!-- Modal -->
  <div class="modal fade" id="formModal" tabindex="-1" role="dialog" aria-labelledby="mdl-add-lbl" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <!-- Modal content-->
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title" id="mdl-add-lbl">Create Ad</h5>
                    <button type="button" class="close text-light" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="name-input">Name</label>
                        <input type="text" asp-for="Name" />
                    </div>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="name-input">Description</label>
                        <input type="text" class="form-control" asp-for="Description" />
                    </div>
                </div>
                <div class="modal-body">
                    <div class="form-group">

						<select asp-for="WorkSpaceDescription" name="studioOptions" onchange="if($(this).val()=='customOption')showCustomInput('studioOptions')">
                                <option></option>
                                <option value="customOption">[Type your own]</option>
                                <option>Music Studio</option>
                                <option>Art Studio</option>
                                <option>Photo Studio</option>
                                <option>Work Shop</option>

                      
                            </select><input name="studioOptions" asp-for="WorkSpaceDescription" style="display:none;" disabled="disabled" onblur="if($(this).val()=='')showOptions('studioOptions')">

                    
              
                    </div>
                </div>
          
